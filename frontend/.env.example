# Copy to `.env` and fill in your own PostgreSQL connection string.
# Used by BOTH the Next.js app (Prisma) and the Python analytics engine.
#
# Local example:
#   postgresql://postgres:YOUR_PASSWORD@localhost:5432/cashflow?schema=public
# Cloud (e.g. Neon — use the POOLED connection string for serverless/Vercel):
#   postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/cashflow?sslmode=require
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/cashflow?schema=public"
